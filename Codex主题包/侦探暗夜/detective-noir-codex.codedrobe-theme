{
  "format": "codedrobe-theme",
  "schemaVersion": 1,
  "theme": {
    "id": "detective-noir-codex",
    "displayName": "侦探暗夜 · Codex",
    "version": "1.0.0",
    "copy": {
      "tagline": "在雨夜与钟摆之间梳理线索。",
      "originality": "所有图形、配色、CSS 与文档均为本仓库原创，不含第三方角色、Logo、截图、台词、音乐或官方界面。"
    }
  },
  "targets": {
    "codex": {
      "css": "/* 侦探暗夜 / codex / 原创致敬主题 */\nhtml.codedrobe-host-codex{--tribute-bg:#08111F;--tribute-surface:#101D2E;--tribute-text:#E7EEF7;--tribute-muted:#8FA3B8;--tribute-accent:#D74B54;--tribute-accent-2:#C9A86A;--tribute-border:#31445A;color-scheme:dark}\nhtml.codedrobe-host-codex body{color:var(--tribute-text);background:radial-gradient(circle at 82% 12%,color-mix(in srgb,var(--tribute-accent-2) 18%,transparent),transparent 38%),linear-gradient(135deg,var(--tribute-bg),var(--tribute-surface)) fixed}\nhtml.codedrobe-host-codex body::before{content:\"\";position:fixed;inset:0;z-index:-1;pointer-events:none;background:repeating-linear-gradient(90deg,transparent 0 47px,color-mix(in srgb,var(--tribute-border) 18%,transparent) 48px),repeating-linear-gradient(0deg,transparent 0 47px,color-mix(in srgb,var(--tribute-border) 18%,transparent) 48px);opacity:.55}\nhtml.codedrobe-host-codex main,html.codedrobe-host-codex [role=\"main\"]{background:color-mix(in srgb,var(--tribute-bg) 78%,transparent);backdrop-filter:blur(14px) saturate(118%)}\nhtml.codedrobe-host-codex aside,html.codedrobe-host-codex nav{background:color-mix(in srgb,var(--tribute-surface) 88%,transparent);backdrop-filter:blur(18px) saturate(120%)}\nhtml.codedrobe-host-codex button,html.codedrobe-host-codex input,html.codedrobe-host-codex textarea,html.codedrobe-host-codex [contenteditable=\"true\"],html.codedrobe-host-codex [role=\"textbox\"]{color:var(--tribute-text);border-color:var(--tribute-border);background:color-mix(in srgb,var(--tribute-surface) 91%,transparent)}\nhtml.codedrobe-host-codex button:hover,html.codedrobe-host-codex [aria-selected=\"true\"],html.codedrobe-host-codex [data-state=\"active\"]{border-color:var(--tribute-accent-2);background:color-mix(in srgb,var(--tribute-accent) 18%,var(--tribute-surface))}\nhtml.codedrobe-host-codex :focus-visible{outline:2px solid var(--tribute-accent-2);outline-offset:2px}html.codedrobe-host-codex a{color:var(--tribute-accent-2)}\nhtml.codedrobe-host-codex pre,html.codedrobe-host-codex code{background:#07101A;color:var(--tribute-text);border-color:var(--tribute-border)}\nhtml.codedrobe-host-codex blockquote{border-left-color:var(--tribute-accent);color:var(--tribute-muted)}html.codedrobe-host-codex ::selection{background:color-mix(in srgb,var(--tribute-accent) 52%,transparent);color:var(--tribute-text)}\nhtml.codedrobe-host-codex .codedrobe-theme-emblem{pointer-events:none;background:var(--codedrobe-image-emblem) center/contain no-repeat}\nhtml.codedrobe-host-codex [data-testid=\"composer\"],html.codedrobe-host-codex [contenteditable=\"true\"],html.codedrobe-host-codex textarea{box-shadow:0 0 0 1px #31445A,0 18px 48px rgba(0,0,0,.28)}\nhtml.codedrobe-host-codex pre{border-left:3px solid #D74B54}\n@media (prefers-reduced-motion:reduce){html.codedrobe-host-codex *,html.codedrobe-host-codex *::before,html.codedrobe-host-codex *::after{animation-duration:.01ms!important;transition-duration:.01ms!important}}\n",
      "options": {
        "rendererProfile": "codex-theme-v1",
        "baseTheme": {"mode": "dark", "accent": "#D74B54", "ink": "#E7EEF7", "surface": "#08111F"}
      },
      "verification": {
        "required": [{"name": "document-body", "any": ["body"]}],
        "recommended": [
          {"name": "main-surface", "any": ["main", "[role=\"main\"]", ".main-content", ".chat-container"]},
          {"name": "composer", "any": ["[contenteditable=\"true\"]", "textarea", "[role=\"textbox\"]"]}
        ],
        "contexts": [{"name": "interactive-page", "when": {"any": ["body"]}, "recommended": [{"name": "codex-navigation", "any": ["nav", "aside", "[role=\"navigation\"]"]}]}]
      }
    }
  },
  "assets": {"images": {"emblem": {"filename": "emblem.png", "mimeType": "image/png", "base64": ""}}}
}
